# Supabase — these are SAFE to expose in the browser. The anon key is
# scoped by RLS policies. Paste the same values into Vercel env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER-ONLY. Bypasses RLS. Used by the
# /api/topics route to insert topics. Never expose. Never commit.
# Grab from: Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of admin email addresses. Anyone whose Supabase
# Auth session matches one of these gets admin powers (publish topics,
# archive, etc.). e.g. ADMIN_EMAILS=peter@sidejar.co,jane@example.com
ADMIN_EMAILS=

# Shared bearer token for the n8n ingest workflow. n8n stores this in
# its credentials and includes it in the Authorization header when
# POSTing to /api/topics. Rotate by generating a new opaque random
# string and updating both this var and n8n's credential.
TOPICS_INGEST_TOKEN=
